# CODE-AI — Root environment variables for Docker Compose
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ---------------------------------------------------------------------------
# LLM Backend
# ---------------------------------------------------------------------------
# "openrouter"  — cloud inference, no GPU needed, parallelism across stages
# "ollama"      — local GPU (Ollama must be running on the host)
LLM_BACKEND=openrouter

# ---------------------------------------------------------------------------
# OpenRouter API Keys
# ---------------------------------------------------------------------------
# Get your key(s) at https://openrouter.ai/keys
#
# PARALLEL RATE LIMITS
# OpenRouter rate limits per key.  Using separate keys per model group
# gives each stage its own rate-limit bucket so all can run concurrently.
# Create up to 4 free accounts to get 4 separate keys, one per group.
#
# Key routing by model pattern:
#   REASONING    → deepseek / r1 models       (preprocessing + RAG stages)
#   CODING       → qwen / coder models         (recommender + verifier stages)
#   INSTRUCTION  → llama models                (validator stage)
#   SUMMARIZE    → mistral models              (reporter stage)

# Master key — fallback when no group-specific key is set
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: per-group keys for maximum parallelism (recommended for production)
OPENROUTER_API_KEY_REASONING=sk-or-v1-...
OPENROUTER_API_KEY_CODING=sk-or-v1-...
OPENROUTER_API_KEY_INSTRUCTION=sk-or-v1-...
OPENROUTER_API_KEY_SUMMARIZE=sk-or-v1-...

# ---------------------------------------------------------------------------
# Optional: OpenAI GPT-4o fallback
# ---------------------------------------------------------------------------
# Only needed for interactive CLI mode (the 'X' option).
# Not used by the web API server.
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Ollama (only needed when LLM_BACKEND=ollama)
# ---------------------------------------------------------------------------
# If Ollama is running on the host and you want the container to reach it:
# OLLAMA_HOST=http://host.docker.internal:11434
