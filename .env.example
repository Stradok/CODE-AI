# CODE-AI — environment variables for Docker Compose
# Copy this file to .env and fill in your values.
# Never commit .env to git.
#
# API KEYS are NOT stored here. Users authenticate via the UI:
#   - OpenRouter: "Sign in with OpenRouter" button (Google OAuth)
#   - Custom mode: users paste their own OpenAI/Anthropic keys in the UI
# Keys travel per-request from the browser — the server holds nothing.

# ---------------------------------------------------------------------------
# LLM Backend default
# ---------------------------------------------------------------------------
LLM_BACKEND=openrouter

# ---------------------------------------------------------------------------
# CORS — REQUIRED after Vercel deployment
# ---------------------------------------------------------------------------
# Your browser (on the Vercel page) calls your local backend directly.
# Add your Vercel URL so the browser request is allowed.
#
# Format: comma-separated, no trailing slash, no spaces.
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ---------------------------------------------------------------------------
# Ollama (only when LLM_BACKEND=ollama)
# ---------------------------------------------------------------------------
# Uncomment if Ollama is on the host and the Docker container needs to reach it:
# OLLAMA_HOST=http://host.docker.internal:11434
