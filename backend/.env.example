# CODE-AI Backend Environment Variables
# Copy this file to .env and fill in your values.
# For Docker Compose use the root .env.example instead.

# ---------------------------------------------------------------------------
# LLM Backend — "ollama" (local GPU, default) or "openrouter" (cloud)
# ---------------------------------------------------------------------------
LLM_BACKEND=ollama

# ---------------------------------------------------------------------------
# OpenRouter (LLM_BACKEND=openrouter)  — https://openrouter.ai/keys
# ---------------------------------------------------------------------------
# Master key — fallback for all model groups
OPENROUTER_API_KEY=

# Per-group keys for parallel rate limits (optional but recommended)
# Each key gets its own rate-limit bucket so all stages can run concurrently.
OPENROUTER_API_KEY_REASONING=        # deepseek/r1 — preprocessing + RAG
OPENROUTER_API_KEY_CODING=           # qwen/coder  — recommender + verifier
OPENROUTER_API_KEY_INSTRUCTION=      # llama       — validator
OPENROUTER_API_KEY_SUMMARIZE=        # mistral     — reporter

# ---------------------------------------------------------------------------
# OpenAI GPT-4o fallback (optional — enables 'X' option in CLI mode)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# FastAPI server settings
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000
HOST=0.0.0.0
PORT=8000
