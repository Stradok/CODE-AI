# CODE-AI Backend Environment Variables
# Copy this file to .env and fill in your values.
# The pipeline runs fully locally without any of these set.

# GPT-4o fallback — optional; enables the 'X' (GPT fix) option in CLI mode
OPENAI_API_KEY=

# CORS allowed origins for the FastAPI server (comma-separated)
# Default: http://localhost:3000 (the Next.js dev server)
ALLOWED_ORIGINS=http://localhost:3000

# Uvicorn bind address and port
HOST=0.0.0.0
PORT=8000
